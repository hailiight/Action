/* ═══════════════════════════════════════════════════════════════
   COLUMN ALIASES
═══════════════════════════════════════════════════════════════ */
const COL_MAP = {
  productcode:   ['productcode','masp','masanpham','sku','skucode','itemcode','mahang','ma','code'],
  productname:   ['productname','tensanpham','tensp','ten','sanpham','itemname','tenhanghoa','name'],
  currentstock:  ['currentstock','tondauky','tonhientai','tonkho','ton','stockcurrent','soluongton','tondaukj','stock'],
  intransit:     ['intransit','hangduong','hangtrenvanchuyen','transit','incoming','hangve','duong'],
  forecaststock: ['forecaststock','tondukien','forecast','toncuoiky','tondukiencuoiky'],
  minstock:      ['minstock','tonmin','tontoithieu','min','toithieu','minimumstock'],
  maxstock:      ['maxstock','tonmax','tontoidatoi','max','toidatoi','maximumstock'],
};
const COLS = Object.keys(COL_MAP);

/* ═══════════════════════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════════════════════ */
function nk(s) {
  return String(s || '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().replace(/[^a-z0-9]/g, '');
}

function clean(s) {
  if (s === null || s === undefined) return '';
  let t = String(s).normalize('NFC');
  t = t.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '')
    .replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>')
    .replace(/&quot;/g,'"').replace(/&apos;/g,"'").replace(/&nbsp;/g,' ')
    .replace(/&#x([0-9A-Fa-f]+);/g, (_,h) => String.fromCharCode(parseInt(h,16)))
    .replace(/&#([0-9]+);/g, (_,d) => String.fromCharCode(parseInt(d,10)))
    .replace(/[ \t]+/g, ' ').trim();
  return t;
}

function parseNum(raw) {
  if (raw === null || raw === undefined || raw === '') return NaN;
  let s = String(raw).trim();
  s = s.replace(/[^\d.,()\-]/g, '');
  if (/^\([\d.,]+\)$/.test(s)) s = '-' + s.slice(1,-1);
  if (!s || s === '-') return NaN;
  const hasDot = s.includes('.');
  const hasComma = s.includes(',');
  if (hasDot && hasComma) {
    if (s.lastIndexOf(',') > s.lastIndexOf('.')) s = s.replace(/\./g,'').replace(',','.');
    else s = s.replace(/,/g,'');
  } else if (hasComma) {
    const parts = s.split(',');
    if (parts.length === 2 && parts[1].length === 3 && !parts[1].includes('.')) s = s.replace(/,/g,'');
    else s = s.replace(',','.');
  } else if (hasDot) {
    const parts = s.split('.');
    if (parts.length === 2 && parts[1].length === 3) s = s.replace(/\./g,'');
  }
  const n = parseFloat(s);
  return isNaN(n) ? NaN : n;
}

function fmt(n) { return Math.round(n).toLocaleString('vi-VN'); }
function fmtSigned(n) {
  if (n < 0) return '−' + fmt(Math.abs(n));
  if (n > 0) return '+' + fmt(n);
  return '0';
}
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function show(id) { const el = document.getElementById(id); if(el) el.style.display = ''; }
function hide(id) { const el = document.getElementById(id); if(el) el.style.display = 'none'; }

function todayVN() {
