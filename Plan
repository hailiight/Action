<script>
/* ═══════════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════════ */
let G = {
  rows: [],
  filter: 'all',
  sort: { col: 'PriorityScore', dir: -1 },
  tab: 'sku',
  capacity: 2000,
  dailySales: 10,
