/* ═══════════════════════════════════════════════════════════════
   ALERTS
═══════════════════════════════════════════════════════════════ */
function addAlert(type, msg) {
  const d = document.createElement('div');
  const icon = type === 'err' ? '🔴' : type === 'warn' ? '🟡' : '🔵';
  d.className = `alert a-${type}`;
  d.innerHTML = `<span>${icon}</span><span>${msg}</span>`;
  document.getElementById('alert-zone').appendChild(d);
}
function clearAlerts() { document.getElementById('alert-zone').innerHTML = ''; }

/* ═══════════════════════════════════════════════════════════════
   PARSE TEXT
═══════════════════════════════════════════════════════════════ */
function parseText(raw) {
  if (!raw.trim()) return { error: 'Chưa có dữ liệu. Hãy dán Excel vào ô nhập liệu hoặc upload file .xlsx.' };
  const text = raw.normalize('NFC').replace(/\r\n/g,'\n').replace(/\r/g,'\n');
  const lines = text.split('\n').map(l => l.trimEnd()).filter(l => l.length > 0);
  if (lines.length < 2) return { error: 'Cần ít nhất 1 dòng tiêu đề + 1 dòng dữ liệu.' };
  const hdr = lines[0];
  let delim = '\t';
  if (!hdr.includes('\t')) { if (hdr.includes(';')) delim = ';'; else if (hdr.includes(',')) delim = ','; }
  const rawHeaders = hdr.split(delim).map(h => nk(h));
  const idx = {};
  for (const col of COLS) { const found = rawHeaders.findIndex(h => COL_MAP[col].includes(h)); idx[col] = found; }
  const required = ['productcode','productname','minstock','maxstock'];
  const missing = required.filter(c => idx[c] === -1);
  if (missing.length) { const hint = missing.map(c => `"${COL_MAP[c][0]}"`).join(', '); return { error: `Thiếu cột bắt buộc: ${hint}. Tên cột EN hoặc VI đều được.` }; }
  const rows = [], warnings = [];
  for (let i = 1; i < lines.length; i++) {
    const cells = lines[i].split(delim);
    const code = clean(cells[idx.productcode] || '');
    const name = clean(cells[idx.productname] || '');
    if (!code && !name) continue;
    const numFields = {
      currentstock:  idx.currentstock  >= 0 ? parseNum(cells[idx.currentstock])  : NaN,
      intransit:     idx.intransit     >= 0 ? parseNum(cells[idx.intransit])     : NaN,
      forecaststock: idx.forecaststock >= 0 ? parseNum(cells[idx.forecaststock]) : NaN,
      minstock:      parseNum(cells[idx.minstock]),
      maxstock:      parseNum(cells[idx.maxstock]),
    };
    if (isNaN(numFields.currentstock)) numFields.currentstock = 0;
    if (isNaN(numFields.intransit))    numFields.intransit    = 0;
    if (isNaN(numFields.forecaststock)) numFields.forecaststock = numFields.currentstock + numFields.intransit;
    let rowOk = true;
    for (const col of ['minstock','maxstock']) {
      if (isNaN(numFields[col])) { warnings.push(`Hàng ${i+1} (${code||name}): cột "${COL_MAP[col][0]}" không hợp lệ → bỏ qua`); rowOk = false; break; }
    }
    if (!rowOk) continue;
    rows.push({ ProductCode: code || String(i), ProductName: name || code || `SKU-${i}`, CurrentStock: numFields.currentstock, InTransit: numFields.intransit, ForecastStock: numFields.forecaststock, MinStock: numFields.minstock, MaxStock: numFields.maxstock });
  }
  if (!rows.length) return { error: 'Không có dòng dữ liệu hợp lệ. ' + (warnings[0] || '') };
  return { rows, warnings };
}

/* ═══════════════════════════════════════════════════════════════
   COMPUTE METRICS
═══════════════════════════════════════════════════════════════ */
function computeMetrics(rawRows) {
  const ds = Math.max(1, parseFloat(document.getElementById('daily-sales').value) || 10);
  const maxMaxStock = Math.max(...rawRows.map(r => r.MaxStock), 1);
  return rawRows.map(r => {
    const AvailableStock = r.CurrentStock + r.InTransit;
    const FinalStock     = r.ForecastStock;
    const MinStock       = r.MinStock;
    const MaxStock       = r.MaxStock;
    let Status;
    if (FinalStock < MinStock) Status = 'CRITICAL';
    else if (FinalStock > MaxStock) Status = 'OVERSTOCK';
    else Status = 'NORMAL';
    const StockGap    = FinalStock - MinStock;
    const ProdToMin   = Status === 'CRITICAL' ? Math.max(0, MinStock - FinalStock) : 0;
    const ProdToMax   = Status === 'CRITICAL' ? Math.max(0, MaxStock - FinalStock) : 0;
    const ProdNeeded  = ProdToMax;
    const MaxW        = MaxStock / maxMaxStock;
    const ShortfallPct = MinStock > 0 ? Math.max(0, (MinStock - FinalStock) / MinStock) : (FinalStock < 0 ? 1 : 0);
    const NegBonus    = FinalStock < 0 ? 1 : 0;
    const DaysCov     = ds > 0 ? AvailableStock / ds : 9999;
    const UrgBonus    = DaysCov < 3 ? 1 : DaysCov < 7 ? 0.5 : 0;
    const CompositeScore = Status === 'CRITICAL' ? 0.40 * MaxW + 0.35 * ShortfallPct + 0.15 * NegBonus + 0.10 * UrgBonus : 0;
    const PriorityScore  = CompositeScore;
    let PriorityTier = 4;
    if (Status === 'CRITICAL') {
      if (FinalStock <= 0 || ShortfallPct >= 0.5 || MaxW >= 0.65) PriorityTier = 1;
      else if (ShortfallPct >= 0.25 || MaxW >= 0.35) PriorityTier = 2;
      else PriorityTier = 3;
    } else if (Status === 'OVERSTOCK') PriorityTier = 5;
    const DaysToMin = ds > 0 && StockGap >= 0 ? StockGap / ds : 0;
    return { ProductCode: r.ProductCode, ProductName: r.ProductName, AvailableStock, FinalStock, MinStock, MaxStock, Status, StockGap, ProdToMin, ProdToMax, ProdNeeded, MaxW, ShortfallPct, NegBonus, UrgBonus, CompositeScore, PriorityScore, PriorityTier, DaysCov, DaysToMin };
  });
}

/* ═══════════════════════════════════════════════════════════════
   DECISION ENGINE
═══════════════════════════════════════════════════════════════ */
function decisionEngine(computed) {
  const cap = Math.max(1, parseFloat(document.getElementById('plant-cap').value) || 2000);
  const criticals = computed.filter(r => r.Status === 'CRITICAL');
  const planRows = [...criticals].sort((a,b) => {
    const dw = b.MaxW - a.MaxW;
    if (Math.abs(dw) > 0.05) return dw;
    return b.CompositeScore - a.CompositeScore;
  });
  const totalNeeded = criticals.reduce((s,r) => s + r.ProdNeeded, 0);
  const overload = totalNeeded > cap * G.horizon;
  return { planRows, totalNeeded, cap, overload };
}

/* ═══════════════════════════════════════════════════════════════
   TOP 15
═══════════════════════════════════════════════════════════════ */
function getTop15(computed) {
  return computed.filter(r => r.Status === 'CRITICAL').sort((a,b) => b.CompositeScore - a.CompositeScore).slice(0, 15);
}

/* ═══════════════════════════════════════════════════════════════
   MAIN RUN
═══════════════════════════════════════════════════════════════ */
function runAll() {
  clearAlerts();
  const raw = document.getElementById('data-input').value;
  const parsed = parseText(raw);
  if (parsed.error) { addAlert('err', parsed.error); hide('kpi-grid'); hide('main-panel'); return; }
  (parsed.warnings || []).slice(0, 3).forEach(w => addAlert('warn', w));
  const computed = computeMetrics(parsed.rows);
  G.rows = computed;
  const { planRows, totalNeeded, cap, overload } = decisionEngine(computed);
  G.capacity   = cap;
  G.dailySales = Math.max(1, parseFloat(document.getElementById('daily-sales').value) || 10);
  G.horizon    = Math.max(1, parseFloat(document.getElementById('horizon').value) || 30);
  renderKPIs(computed, totalNeeded, cap);
  if (overload) addAlert('warn', `⚠ Quá tải: cần ${fmt(totalNeeded)} units > công suất ${G.horizon} ngày = ${fmt(cap * G.horizon)} units`);
  G.filter = 'all';
  G.sort = { col: 'PriorityScore', dir: -1 };
  document.querySelectorAll('.seg-btn').forEach(b => b.classList.toggle('active', b.dataset.f === 'all'));
  renderSKU();
  renderTop15(computed);
  renderOrder(planRows, totalNeeded, cap);
  renderWarnings(computed, overload, cap, totalNeeded);
  show('kpi-grid');
  show('main-panel');
  document.getElementById('hdr-time').textContent = 'Cập nhật: ' + new Date().toLocaleTimeString('vi-VN');
  // Update PO display info
  document.getElementById('po-horizon-disp').value = G.horizon + ' ngày';
  document.getElementById('po-cap-disp').value = fmt(G.capacity) + ' units/ngày';
  document.getElementById('po-sales-disp').value = fmt(G.dailySales) + ' units/ngày';
}

/* ═══════════════════════════════════════════════════════════════
   RENDER: KPI CARDS
═══════════════════════════════════════════════════════════════ */
function renderKPIs(rows, totalNeeded, cap) {
  const crit = rows.filter(r => r.Status === 'CRITICAL').length;
  const over = rows.filter(r => r.Status === 'OVERSTOCK').length;
  const ok   = rows.filter(r => r.Status === 'NORMAL').length;
  const pct  = Math.round((totalNeeded / (cap * G.horizon)) * 100);
  document.getElementById('k-total').textContent = rows.length;
  document.getElementById('k-crit').textContent  = crit;
  document.getElementById('k-over').textContent  = over;
  document.getElementById('k-prod').textContent  = fmt(totalNeeded);
  document.getElementById('k-cap').textContent   = pct + '%';
  document.getElementById('k-ok').textContent    = ok;
  const bar = document.getElementById('cap-bar');
  bar.style.width      = Math.min(100, pct) + '%';
  bar.style.background = pct >= 100 ? 'var(--red)' : pct >= 80 ? 'var(--amber)' : '#4ADE80';
  document.getElementById('kpi-grid').style.display = 'grid';
}

/* ═══════════════════════════════════════════════════════════════
   RENDER: SKU TABLE
═══════════════════════════════════════════════════════════════ */
function renderSKU() {
  const filtered = G.filter === 'all' ? G.rows : G.rows.filter(r => r.Status === G.filter);
  const sorted = [...filtered].sort((a,b) => {
    const av = a[G.sort.col], bv = b[G.sort.col];
    if (typeof av === 'string') return G.sort.dir * av.localeCompare(bv, 'vi');
    return G.sort.dir * ((bv ?? 0) - (av ?? 0));
  });
  const tbody = document.getElementById('sku-body');
  if (!sorted.length) { tbody.innerHTML = `<tr><td colspan="10"><div class="empty"><div class="empty-icon">🔍</div><div class="empty-txt">Không có SKU phù hợp</div></div></td></tr>`; }
  else {
    tbody.innerHTML = sorted.map(r => {
      const rc = r.Status === 'CRITICAL' ? 'r-crit' : r.Status === 'OVERSTOCK' ? 'r-over' : 'r-ok';
      const statBadge = r.Status === 'CRITICAL' ? `<span class="badge b-crit">Khẩn Cấp</span>` : r.Status === 'OVERSTOCK' ? `<span class="badge b-over">Tồn Thừa</span>` : `<span class="badge b-ok">Ổn Định</span>`;
      const gapClass = r.StockGap < 0 ? 'n-red' : 'n-green';
      const mwPct = Math.round(r.MaxW * 100);
      const mwColor = mwPct >= 70 ? 'var(--gold)' : mwPct >= 40 ? 'var(--blue)' : 'var(--muted3)';
      const finalClass = r.FinalStock < 0 ? 'n-red' : '';
      const dayClass = r.DaysCov < 3 ? 'n-red' : r.DaysCov < 7 ? 'n-amber' : r.DaysCov > 60 ? 'n-blue' : '';
      return `<tr class="${rc}">
        <td><span class="sku-chip">${esc(r.ProductCode)}</span></td>
        <td style="font-weight:600;max-width:240px;overflow:hidden;text-overflow:ellipsis" title="${esc(r.ProductName)}">${esc(r.ProductName)}</td>
        <td class="r ${finalClass}">${fmt(r.FinalStock)}</td>
        <td class="r n-muted">${fmt(r.MinStock)} / ${fmt(r.MaxStock)}</td>
        <td class="r ${gapClass}">${fmtSigned(r.StockGap)}</td>
        <td>${statBadge}</td>
        <td>${tierBadge(r.PriorityTier, r.Status)}</td>
        <td class="r">${r.ProdNeeded > 0 ? `<span class="n-red">${fmt(r.ProdNeeded)}</span>` : `<span class="n-muted">—</span>`}</td>
        <td class="r">
          <div class="mini-bar">
            <div class="mini-bar-bg"><div class="mini-bar-fg" style="width:${mwPct}%;background:${mwColor}"></div></div>
            <span class="mini-bar-lbl">${mwPct}%</span>
          </div>
        </td>
        <td class="r ${dayClass}">${r.DaysCov.toFixed(1)}</td>
      </tr>`;
    }).join('');
  }
  document.getElementById('rc-sku').textContent  = `${sorted.length} / ${G.rows.length} SKU`;
  document.getElementById('rc-sku2').textContent = `Hiển thị ${sorted.length} / ${G.rows.length} SKU`;
  document.querySelectorAll('th .si').forEach(el => {
    const col = el.dataset.col;
    if (!col) return;
    el.parentElement.classList.toggle('sorted', col === G.sort.col);
    el.textContent = col === G.sort.col ? (G.sort.dir === -1 ? '↓' : '↑') : '↕';
  });
}

/* ═══════════════════════════════════════════════════════════════
   RENDER: TOP 15
═══════════════════════════════════════════════════════════════ */
function renderTop15(computed) {
  const top = getTop15(computed);
  document.getElementById('rc-top').textContent = `${top.length} SKU ưu tiên cao nhất`;
  const tbody = document.getElementById('top-body');
  if (!top.length) { tbody.innerHTML = `<tr><td colspan="12"><div class="empty"><div class="empty-icon">✅</div><div class="empty-txt">Không có SKU khẩn cấp</div></div></td></tr>`; document.getElementById('top-foot').innerHTML = ''; return; }
  tbody.innerHTML = top.map((r, i) => {
    const rank = i + 1;
    const rankClass = rank === 1 ? 'rank-1' : rank === 2 ? 'rank-2' : rank === 3 ? 'rank-3' : 'rank-n';
    const ph1 = r.FinalStock < 0 ? Math.abs(r.FinalStock) : 0;
    const ph2 = r.ProdToMin;
    const ph3 = r.ProdToMax - r.ProdToMin;
    const total = r.ProdToMax || 1;
    const w1 = Math.round((ph1 / total) * 100);
    const w2 = Math.round((ph2 / total) * 100);
    const w3 = Math.round((ph3 / total) * 100);
    const phaseHtml = r.ProdNeeded > 0 ? `
      <div class="phase-wrap" title="Đỏ: cứu âm · Cam: lên Min · Xanh: lên Max">
        ${ph1 > 0 ? `<div class="phase-seg" style="flex:${w1};background:var(--red);min-width:3px"></div>` : ''}
        ${ph2 > 0 ? `<div class="phase-seg" style="flex:${w2};background:var(--amber);min-width:3px"></div>` : ''}
        ${ph3 > 0 ? `<div class="phase-seg" style="flex:${w3};background:var(--green);min-width:3px"></div>` : ''}
      </div>` : `<span class="n-muted">—</span>`;
    const finalClass = r.FinalStock < 0 ? 'n-red' : 'n-amber';
    const scoreColor = r.CompositeScore >= 0.7 ? 'n-red' : r.CompositeScore >= 0.4 ? 'n-amber' : 'n-blue';
    return `<tr>
      <td><div class="rank-badge ${rankClass}">${rank}</div></td>
      <td><span class="sku-chip">${esc(r.ProductCode)}</span></td>
      <td style="font-weight:700;max-width:220px;overflow:hidden;text-overflow:ellipsis">${esc(r.ProductName)}</td>
      <td class="r ${finalClass}">${fmt(r.FinalStock)}</td>
      <td class="r n-muted">${fmt(r.MinStock)}</td>
      <td class="r n-blue">${fmt(r.MaxStock)}</td>
      <td class="r n-red">${fmt(Math.abs(r.StockGap))}</td>
      <td class="r">${r.ProdToMin > 0 ? fmt(r.ProdToMin) : '<span class="n-muted">—</span>'}</td>
      <td class="r n-blue">${r.ProdNeeded > 0 ? fmt(r.ProdNeeded) : '<span class="n-muted">—</span>'}</td>
      <td class="r ${scoreColor}">${(r.CompositeScore * 100).toFixed(1)}</td>
      <td>${phaseHtml}</td>
      <td>${tierBadge(r.PriorityTier, r.Status)}</td>
    </tr>`;
  }).join('');
  const totMin = top.reduce((s,r) => s + r.ProdToMin, 0);
  const totMax = top.reduce((s,r) => s + r.ProdNeeded, 0);
  const negCnt = top.filter(r => r.FinalStock < 0).length;
  const capPct = Math.round((totMax / (G.capacity * G.horizon)) * 100);
  document.getElementById('top-foot').innerHTML = `
    <div class="plan-foot-cell"><div class="plan-foot-lbl">SKU Tồn Âm</div><div class="plan-foot-val n-red">${negCnt}</div></div>
    <div class="plan-foot-cell"><div class="plan-foot-lbl">SX Đạt Min (Khẩn)</div><div class="plan-foot-val n-amber">${fmt(totMin)}</div></div>
    <div class="plan-foot-cell"><div class="plan-foot-lbl">SX Đạt Max (Đầy Đủ)</div><div class="plan-foot-val n-blue">${fmt(totMax)}</div></div>
    <div class="plan-foot-cell"><div class="plan-foot-lbl">% Công Suất ${G.horizon}N</div><div class="plan-foot-val" style="color:${capPct>=100?'var(--red)':capPct>=80?'var(--amber)':'var(--green)'}">${capPct}%</div></div>`;
}

/* ═══════════════════════════════════════════════════════════════
   RENDER: LỆNH SẢN XUẤT (PRODUCTION ORDER)
═══════════════════════════════════════════════════════════════ */
function renderOrder(planRows, totalNeeded, cap) {
  // Init PO fields on first render
  initPOFields();

  document.getElementById('rc-order').textContent = `${planRows.length} SKU cần sản xuất`;

  // Summary
  const p1 = planRows.filter(r => r.PriorityTier === 1).length;
  const p2 = planRows.filter(r => r.PriorityTier === 2).length;
  const totMin = planRows.reduce((s,r) => s + r.ProdToMin, 0);
  const totMax = planRows.reduce((s,r) => s + r.ProdNeeded, 0);
  document.getElementById('pos-sku').textContent = planRows.length;
  document.getElementById('pos-p1').textContent  = p1;
  document.getElementById('pos-p2').textContent  = p2;
  document.getElementById('pos-min').textContent = fmt(totMin);
  document.getElementById('pos-max').textContent = fmt(totMax);

  const tbody = document.getElementById('order-body');
  const ds = G.dailySales;

  if (!planRows.length) {
    tbody.innerHTML = `<tr><td colspan="12" style="text-align:center;padding:40px;color:var(--muted2)">
      <div style="font-size:28px;margin-bottom:10px">✅</div>
      <div>Không có SKU cần sản xuất — Tất cả trong ngưỡng an toàn</div>
    </td></tr>`;
    return;
  }

  tbody.innerHTML = planRows.map((r, i) => {
    const tierLabel = r.PriorityTier === 1 ? `<span class="po-tier-1">🔴 P1 — Khẩn Cấp</span>` : r.PriorityTier === 2 ? `<span class="po-tier-2">🟡 P2 — Cao</span>` : `<span class="po-tier-3">🔵 P3 — Bình Thường</span>`;
    const finalClass = r.FinalStock < 0 ? 'td-urgent' : 'td-normal';
    const daysLeft = r.FinalStock > 0 ? (r.FinalStock / ds).toFixed(0) : '0';
    const dlStyle = parseFloat(daysLeft) < 3 ? 'color:var(--red);font-weight:700' : parseFloat(daysLeft) < 7 ? 'color:var(--amber);font-weight:600' : 'color:var(--green)';
    const rowBg = r.PriorityTier === 1 ? 'background:rgba(214,48,48,0.03)' : r.PriorityTier === 2 ? 'background:rgba(196,122,0,0.03)' : '';
    return `<tr style="${rowBg}">
      <td class="td-center" style="font-family:var(--mono);font-size:10px;color:var(--muted2);font-weight:600">${String(i+1).padStart(2,'0')}</td>
      <td class="td-code">${esc(r.ProductCode)}</td>
      <td class="td-name" title="${esc(r.ProductName)}">${esc(r.ProductName)}</td>
      <td class="td-center">${tierLabel}</td>
      <td class="td-right ${finalClass}">${fmt(r.FinalStock)}</td>
      <td class="td-right" style="color:var(--muted)">${fmt(r.MinStock)}</td>
      <td class="td-right" style="color:var(--blue)">${fmt(r.MaxStock)}</td>
      <td class="td-right n-red">−${fmt(Math.abs(r.StockGap))}</td>
      <td class="td-right" style="color:var(--amber);font-weight:700;font-family:var(--mono);background:rgba(196,122,0,0.04)">${fmt(r.ProdToMin)}</td>
      <td class="td-right" style="color:var(--blue);font-weight:800;font-family:var(--mono);background:rgba(26,95,200,0.04)">${fmt(r.ProdNeeded)}</td>
      <td class="td-center" style="${dlStyle}">${daysLeft} ngày</td>
      <td></td>
    </tr>`;
  }).join('');
}

/* ═══════════════════════════════════════════════════════════════
   RENDER: CẢNH BÁO
═══════════════════════════════════════════════════════════════ */
function renderWarnings(rows, overload, cap, totalNeeded) {
  const wb = document.getElementById('warn-body');
  const crits    = rows.filter(r => r.Status === 'CRITICAL');
  const p1       = crits.filter(r => r.PriorityTier === 1);
  const p2       = crits.filter(r => r.PriorityTier === 2);
  const p3       = crits.filter(r => r.PriorityTier === 3);
  const negStock = crits.filter(r => r.FinalStock < 0);
  const overstock= rows.filter(r => r.Status === 'OVERSTOCK');
  let html = '';
  if (overload) html += warnBlock('wb-red', '⚠️ QUÁ TẢI SẢN XUẤT', `Nhu cầu <b>${fmt(totalNeeded)}</b> units vượt công suất ${G.horizon} ngày = <b>${fmt(cap * G.horizon)}</b> units. Cần phân kỳ lệnh hoặc tăng ca.`);
  if (negStock.length) html += warnBlock('wb-red', `🔴 TỒN KHO ÂM — ${negStock.length} SKU`, negStock.map(r => `• <b>${esc(r.ProductCode)}</b> ${esc(r.ProductName)}: tồn <b style="color:var(--red)">${fmt(r.FinalStock)}</b> · Min ${fmt(r.MinStock)} · SX cần ${fmt(r.ProdNeeded)}`).join('<br>'));
  if (p1.length) html += warnBlock('wb-red', `🚨 ƯU TIÊN 1 — ${p1.length} SKU`, p1.map(r => `• <b>${esc(r.ProductCode)}</b> ${esc(r.ProductName)}: tồn ${fmt(r.FinalStock)} / min ${fmt(r.MinStock)} · Thiếu ${fmt(Math.abs(r.StockGap))} · Score ${(r.CompositeScore*100).toFixed(0)}`).join('<br>'));
  if (p2.length) html += warnBlock('wb-amb', `🟡 ƯU TIÊN 2 — ${p2.length} SKU`, p2.map(r => `• <b>${esc(r.ProductCode)}</b> ${esc(r.ProductName)}: tồn ${fmt(r.FinalStock)} / min ${fmt(r.MinStock)} · Thiếu ${fmt(Math.abs(r.StockGap))}`).join('<br>'));
  if (p3.length) html += warnBlock('wb-amb', `🟠 ƯU TIÊN 3 — ${p3.length} SKU`, p3.map(r => `• <b>${esc(r.ProductCode)}</b> ${esc(r.ProductName)}: tồn ${fmt(r.FinalStock)} / min ${fmt(r.MinStock)}`).join('<br>'));
  if (overstock.length) html += warnBlock('wb-blue', `📦 ${overstock.length} SKU Tồn Thừa — cân nhắc dừng sản xuất`, overstock.map(r => `• <b>${esc(r.ProductCode)}</b> ${esc(r.ProductName)}: tồn ${fmt(r.FinalStock)} · Max ${fmt(r.MaxStock)} (+${fmt(r.FinalStock - r.MaxStock)})`).join('<br>'));
  if (!html) html = `<div class="empty"><div class="empty-icon">✅</div><div class="empty-txt">Không có cảnh báo</div></div>`;
  wb.innerHTML = html;
  document.getElementById('tab-warn').textContent = `🚨 Cảnh Báo${crits.length ? ` (${crits.length})` : ''}`;
}

function warnBlock(cls, title, body) {
  return `<div class="warn-block ${cls}"><div class="warn-block-head">${title}</div><div class="warn-block-body">${body}</div></div>`;
}

/* ═══════════════════════════════════════════════════════════════
   TIER BADGE
═══════════════════════════════════════════════════════════════ */
function tierBadge(tier, status) {
  if (status !== 'CRITICAL') return `<span class="badge b-ok2">Ổn Định</span>`;
  if (tier === 1) return `<span class="badge b-p1">P1 Khẩn</span>`;
  if (tier === 2) return `<span class="badge b-p2">P2</span>`;
  return `<span class="badge b-p3">P3</span>`;
}

/* ═══════════════════════════════════════════════════════════════
   UI: TAB / FILTER / SORT
═══════════════════════════════════════════════════════════════ */
function switchTab(tab) {
  G.tab = tab;
  ['sku','top','order','warn'].forEach(t => {
    document.getElementById('pane-' + t).style.display = t === tab ? '' : 'none';
    document.getElementById('tab-' + t).classList.toggle('active', t === tab);
  });
}

function setFilter(f) {
  G.filter = f;
  document.querySelectorAll('.seg-btn').forEach(b => b.classList.toggle('active', b.dataset.f === f));
  renderSKU();
}

function sortBy(col) {
  if (G.sort.col === col) G.sort.dir *= -1;
  else { G.sort.col = col; G.sort.dir = -1; }
  renderSKU();
}

