   XLSX BUILDER (Pure JS — no library needed)
   Creates a valid .xlsx file with basic formatting
═══════════════════════════════════════════════════════════════ */
function buildAndDownloadXLSX(rows, filename, customColWidths) {
  // Shared strings
  const strings = [];
  const strMap  = {};
  function addStr(s) {
    const key = String(s ?? '');
    if (strMap[key] === undefined) { strMap[key] = strings.length; strings.push(key); }
    return strMap[key];
  }

  // Style registry
  const fonts   = [];
  const fills   = [];
  const borders = [];
  const cellXfs = [];

  function addFont(bold, sz, color) {
    const k = `${bold}|${sz||11}|${color||'000000'}`;
    const found = fonts.findIndex(f => f._k === k);
    if (found >= 0) return found;
    fonts.push({_k:k, bold, sz: sz||11, color: color||'000000'});
    return fonts.length - 1;
  }

  function addFill(bg) {
    if (!bg) { const f = fills.findIndex(f => f.type === 'none'); if(f>=0) return f; fills.push({type:'none'}); return fills.length-1; }
    const k = bg;
    const found = fills.findIndex(f => f.bg === k);
    if (found >= 0) return found;
    fills.push({bg});
    return fills.length - 1;
  }

  // Pre-add required fills (OpenXML requires at least 2)
  fills.push({type:'none'});  // 0: none
  fills.push({type:'gray125'}); // 1: gray125 (required)
  addFont(false, 11, '000000'); // 0: default

  function addBorder() {
    if (!borders.length) borders.push({thin:true});
    return 0;
  }
  addBorder();

  function getXf(bold, sz, color, bg, align) {
    const fId = addFont(bold, sz, color);
    const bgId = addFill(bg);
    const bId = 0;
    const k = `${fId}|${bgId}|${align||'left'}`;
    const found = cellXfs.findIndex(x => x._k === k);
    if (found >= 0) return found;
    cellXfs.push({_k:k, fId, bgId, bId, align: align||'left'});
    return cellXfs.length - 1;
  }
  getXf(false,11,'000000',null,'left'); // 0: default

  // Build cell XML
  function cellXml(r, c, cell) {
    if (!cell || cell.v === null || cell.v === undefined || cell.v === '') return '';
    const isNum  = cell.num && typeof cell.v === 'number';
    const xfIdx  = getXf(cell.bold||false, cell.sz||11, (cell.fc||cell.color||'000000'), cell.bg||null, cell.align||'left');
    const colLetter = numToCol(c);
    const addr = `${colLetter}${r}`;
    if (isNum) {
      return `<c r="${addr}" s="${xfIdx}" t="n"><v>${cell.v}</v></c>`;
    } else {
      const si = addStr(String(cell.v));
      return `<c r="${addr}" s="${xfIdx}" t="s"><v>${si}</v></c>`;
    }
  }

  function numToCol(n) {
    let s = '';
    n++;
    while (n > 0) { const m = (n-1) % 26; s = String.fromCharCode(65+m) + s; n = Math.floor((n-1)/26); }
    return s;
  }

  // Build sheet data & collect merges
  let sheetXml = '<sheetData>';
  const merges = [];
  let rIdx = 1;
  for (const row of rows) {
    if (!row || !row.length) { rIdx++; continue; }
    sheetXml += `<row r="${rIdx}">`;
    let cIdx = 0;
    for (const cell of row) {
      if (!cell) { cIdx++; continue; }
      if (cell.merge && cell.merge > 0) {
        const startCol = numToCol(cIdx);
        const endCol   = numToCol(cIdx + cell.merge - 1);
        merges.push(`<mergeCell ref="${startCol}${rIdx}:${endCol}${rIdx}"/>`);
      }
      sheetXml += cellXml(rIdx, cIdx, cell);
      cIdx++;
    }
    sheetXml += '</row>';
    rIdx++;
  }
  sheetXml += '</sheetData>';

  if (merges.length) sheetXml += `<mergeCells count="${merges.length}">${merges.join('')}</mergeCells>`;

  // Column widths
  const colWidths = customColWidths || [5,14,36,18,12,12,12,12,18,18,14,20];
  const colXml = '<cols>' + colWidths.map((w,i) => `<col min="${i+1}" max="${i+1}" width="${w}" customWidth="1"/>`).join('') + '</cols>';

  // Build style XML
  function xmlFonts() {
    return '<fonts count="' + fonts.length + '">' + fonts.map(f => `<font><sz val="${f.sz}"/><color rgb="FF${f.color}"/><name val="Arial"/>${f.bold?'<b/>':''}</font>`).join('') + '</fonts>';
  }
  function xmlFills() {
    return '<fills count="' + fills.length + '">' + fills.map(f => {
      if (f.type === 'none') return '<fill><patternFill patternType="none"/></fill>';
      if (f.type === 'gray125') return '<fill><patternFill patternType="gray125"/></fill>';
      return `<fill><patternFill patternType="solid"><fgColor rgb="FF${f.bg}"/></patternFill></fill>`;
    }).join('') + '</fills>';
  }
  function xmlBorders() {
    return '<borders count="1"><border><left/><right/><top/><bottom/><diagonal/></border></borders>';
  }
  function xmlCellXfs() {
    return '<cellXfs>' + cellXfs.map(x => `<xf numFmtId="0" fontId="${x.fId}" fillId="${x.bgId}" borderId="0" xfId="0"${x.align && x.align !== 'left' ? ` applyAlignment="1"` : ''}>${x.align && x.align !== 'left' ? `<alignment horizontal="${x.align}"/>` : ''}</xf>`).join('') + '</cellXfs>';
  }

  const styleXml = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<styleSheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">
${xmlFonts()}
${xmlFills()}
${xmlBorders()}
<cellStyleXfs count="1"><xf numFmtId="0" fontId="0" fillId="0" borderId="0"/></cellStyleXfs>
${xmlCellXfs()}
</styleSheet>`;

  // Shared strings XML
  const ssXml = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<sst xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" count="${strings.length}" uniqueCount="${strings.length}">
${strings.map(s => `<si><t xml:space="preserve">${xmlEsc(s)}</t></si>`).join('')}
</sst>`;

  // Worksheet XML
  const wsXml = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<worksheet xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main">
<sheetView workbookViewId="0"><selection activeCell="A1" sqref="A1"/></sheetView>
${colXml}
${sheetXml}
</worksheet>`;

  // Workbook
  const wbXml = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<workbook xmlns="http://schemas.openxmlformats.org/spreadsheetml/2006/main" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships">
<sheets><sheet name="Lenh San Xuat" sheetId="1" r:id="rId1"/></sheets>
</workbook>`;

  const wbRels = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
<Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet" Target="worksheets/sheet1.xml"/>
<Relationship Id="rId2" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/sharedStrings" Target="sharedStrings.xml"/>
<Relationship Id="rId3" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles" Target="styles.xml"/>
</Relationships>`;

  const contentTypes = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Types xmlns="http://schemas.openxmlformats.org/package/2006/content-types">
<Default Extension="rels" ContentType="application/vnd.openxmlformats-package.relationships+xml"/>
<Default Extension="xml" ContentType="application/xml"/>
<Override PartName="/xl/workbook.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml"/>
<Override PartName="/xl/worksheets/sheet1.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml"/>
<Override PartName="/xl/sharedStrings.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.sharedStrings+xml"/>
<Override PartName="/xl/styles.xml" ContentType="application/vnd.openxmlformats-officedocument.spreadsheetml.styles+xml"/>
</Types>`;

  const rootRels = `<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<Relationships xmlns="http://schemas.openxmlformats.org/package/2006/relationships">
<Relationship Id="rId1" Type="http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument" Target="xl/workbook.xml"/>
</Relationships>`;

  // Build ZIP
  const zip = new ZipBuilder();
  zip.addFile('[Content_Types].xml',  str2ab(contentTypes));
  zip.addFile('_rels/.rels',          str2ab(rootRels));
  zip.addFile('xl/workbook.xml',      str2ab(wbXml));
  zip.addFile('xl/_rels/workbook.xml.rels', str2ab(wbRels));
  zip.addFile('xl/worksheets/sheet1.xml',   str2ab(wsXml));
  zip.addFile('xl/sharedStrings.xml', str2ab(ssXml));
  zip.addFile('xl/styles.xml',        str2ab(styleXml));

  const blob = zip.build();
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = filename;
  a.click();
  setTimeout(() => URL.revokeObjectURL(a.href), 5000);
}

function xmlEsc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&apos;');
}

function str2ab(str) {
  const enc = new TextEncoder();
  return enc.encode(str);
}

/* ═══════════════════════════════════════════════════════════════
   ZIP BUILDER — pure JS, no compression (stored)
═══════════════════════════════════════════════════════════════ */
class ZipBuilder {
  constructor() { this.files = []; }

  addFile(name, data) {
    const nameBytes = new TextEncoder().encode(name);
    const crc = crc32(data);
    this.files.push({ name, nameBytes, data, crc });
  }

  build() {
    const parts = [];
    const centralDir = [];
    let offset = 0;

    for (const f of this.files) {
      const lhSize = 30 + f.nameBytes.length;
      const lh = new Uint8Array(lhSize);
      const lv = new DataView(lh.buffer);
      lv.setUint32(0,  0x04034b50, true); // sig
      lv.setUint16(4,  20, true);          // version needed
      lv.setUint16(6,  0, true);           // flags
      lv.setUint16(8,  0, true);           // method: stored
      lv.setUint16(10, 0, true);           // mod time
      lv.setUint16(12, 0, true);           // mod date
      lv.setUint32(14, f.crc, true);
      lv.setUint32(18, f.data.length, true);
      lv.setUint32(22, f.data.length, true);
      lv.setUint16(26, f.nameBytes.length, true);
      lv.setUint16(28, 0, true);
      lh.set(f.nameBytes, 30);
      parts.push(lh);
      parts.push(f.data);

      // Central directory entry
      const cdSize = 46 + f.nameBytes.length;
      const cd = new Uint8Array(cdSize);
      const cv = new DataView(cd.buffer);
      cv.setUint32(0,  0x02014b50, true);
      cv.setUint16(4,  20, true);
      cv.setUint16(6,  20, true);
      cv.setUint16(8,  0, true);
      cv.setUint16(10, 0, true);
      cv.setUint16(12, 0, true);
      cv.setUint16(14, 0, true);
      cv.setUint32(16, f.crc, true);
      cv.setUint32(20, f.data.length, true);
      cv.setUint32(24, f.data.length, true);
      cv.setUint16(28, f.nameBytes.length, true);
      cv.setUint16(30, 0, true);
      cv.setUint16(32, 0, true);
      cv.setUint16(34, 0, true);
      cv.setUint16(36, 0, true);
      cv.setUint32(38, 0, true);
      cv.setUint32(42, offset, true);
      cd.set(f.nameBytes, 46);
      centralDir.push(cd);

      offset += lhSize + f.data.length;
    }

    const cdBytes = concat(centralDir);
    const eocd = new Uint8Array(22);
    const ev   = new DataView(eocd.buffer);
    ev.setUint32(0, 0x06054b50, true);
    ev.setUint16(4, 0, true);
    ev.setUint16(6, 0, true);
    ev.setUint16(8, this.files.length, true);
    ev.setUint16(10, this.files.length, true);
    ev.setUint32(12, cdBytes.length, true);
    ev.setUint32(16, offset, true);
    ev.setUint16(20, 0, true);

    return new Blob([...parts, cdBytes, eocd], { type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' });
  }
}

function concat(arrays) {
  const total = arrays.reduce((s,a) => s + a.length, 0);
  const out = new Uint8Array(total);
  let off = 0;
  for (const a of arrays) { out.set(a, off); off += a.length; }
  return out;
}

// CRC32 lookup table
const CRC_TABLE = (() => {
  const t = new Uint32Array(256);
  for (let i = 0; i < 256; i++) {
    let c = i;
    for (let j = 0; j < 8; j++) c = (c & 1) ? 0xEDB88320 ^ (c >>> 1) : c >>> 1;
    t[i] = c;
  }
  return t;
})();

function crc32(data) {
  let crc = 0xFFFFFFFF;
  for (let i = 0; i < data.length; i++) crc = CRC_TABLE[(crc ^ data[i]) & 0xFF] ^ (crc >>> 8);
  return (crc ^ 0xFFFFFFFF) >>> 0;
}

/* ═══════════════════════════════════════════════════════════════
   XLSX PARSER (từ v7 — giữ nguyên)
═══════════════════════════════════════════════════════════════ */
async function handleExcel(evt) {
  const file = evt.target.files[0];
  evt.target.value = '';
  if (!file) return;
  if (!/\.xlsx$/i.test(file.name)) { clearAlerts(); addAlert('err', 'Chỉ hỗ trợ file .xlsx. Hãy Save As → Excel Workbook (.xlsx) từ Excel.'); return; }
  addAlert('info', `Đang đọc file: ${esc(file.name)} …`);
  try {
    const ab    = await readFileAsArrayBuffer(file);
    const files = await decompressZip(new Uint8Array(ab));
    const ss    = getSharedStrings(files);
    const rows  = extractXlsxData(files, ss);
    if (!rows.length) { clearAlerts(); addAlert('err', 'Không đọc được dữ liệu. Thử: File → Save As → CSV UTF-8 rồi paste vào ô nhập liệu.'); return; }
    const lines = ['ProductCode\tProductName\tCurrentStock\tInTransit\tForecastStock\tMinStock\tMaxStock', ...rows.map(r => [r.code, r.name, r.current, r.transit, r.forecast, r.min, r.max].join('\t'))];
    document.getElementById('data-input').value = lines.join('\n');
    clearAlerts();
    addAlert('info', `✅ Đã import ${rows.length} sản phẩm từ "${esc(file.name)}"`);
    runAll();
  } catch (err) {
    clearAlerts();
    addAlert('err', `Lỗi đọc xlsx: ${esc(err.message)}. Thử export CSV từ Excel.`);
  }
}

function readFileAsArrayBuffer(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = e => resolve(e.target.result);
    reader.onerror = () => reject(new Error('Không đọc được file'));
    reader.readAsArrayBuffer(file);
  });
}

function scanZipEntries(bytes) {
  const view = new DataView(bytes.buffer, bytes.byteOffset, bytes.byteLength);
  const entries = [];
  let i = 0;
  while (i <= bytes.length - 30) {
    if (view.getUint32(i, true) !== 0x04034b50) { i++; continue; }
    const method   = view.getUint16(i + 8,  true);
    const compSize = view.getUint32(i + 18, true);
    const fnLen    = view.getUint16(i + 26, true);
    const exLen    = view.getUint16(i + 28, true);
    const fnBytes  = bytes.subarray(i + 30, i + 30 + fnLen);
    let fname = '';
    for (let fi = 0; fi < fnBytes.length; fi++) fname += String.fromCharCode(fnBytes[fi]);
    const dataStart = i + 30 + fnLen + exLen;
    const data      = bytes.subarray(dataStart, dataStart + compSize);
    if (/\.(xml|rels)$/i.test(fname)) entries.push({ fname, method, data: data.slice() });
    i = dataStart + compSize;
  }
  return entries;
}

async function inflateRaw(data) {
  const ds = new DecompressionStream('deflate-raw');
  const writer = ds.writable.getWriter();
  const reader = ds.readable.getReader();
  const writePromise = (async () => { await writer.write(data); await writer.close(); })();
  const chunks = [];
  while (true) { const { value, done } = await reader.read(); if (done) break; chunks.push(value); }
  await writePromise;
  const totalLen = chunks.reduce((s,c) => s + c.length, 0);
  const out = new Uint8Array(totalLen);
  let offset = 0;
  for (const chunk of chunks) { out.set(chunk, offset); offset += chunk.length; }
  return out;
}

async function decompressZip(bytes) {
  const entries = scanZipEntries(bytes);
  const files   = {};
  for (const entry of entries) {
    try {
      if (entry.method === 0) files[entry.fname] = entry.data;
      else if (entry.method === 8) files[entry.fname] = await inflateRaw(entry.data);
    } catch (_) {}
  }
  return files;
}

function getSharedStrings(files) {
  const key = Object.keys(files).find(k => /sharedStrings\.xml$/i.test(k));
  if (!key) return [];
  const xml    = decodeUTF8(files[key]);
  const blocks = xml.match(/<si>[\s\S]*?<\/si>/g) || [];
  return blocks.map(si => {
    const texts = si.match(/<t(?:\s[^>]*)?>([^<]*)<\/t>/g) || [];
    return xmlUnesc(texts.map(t => t.replace(/<t(?:\s[^>]*)?>/, '').replace(/<\/t>/, '')).join(''));
  });
}

function decodeUTF8(bytes) {
  try { return new TextDecoder('utf-8').decode(bytes); }
  catch (_) { let s = ''; for (let i = 0; i < bytes.length; i++) s += String.fromCharCode(bytes[i]); try { return decodeURIComponent(escape(s)); } catch (_) { return s; } }
}

function xmlUnesc(s) {
  return String(s || '').replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').replace(/&quot;/g,'"').replace(/&apos;/g,"'").replace(/&#x([0-9A-Fa-f]+);/g,(_,h)=>String.fromCharCode(parseInt(h,16))).replace(/&#([0-9]+);/g,(_,d)=>String.fromCharCode(parseInt(d,10)));
}

function colToIdx(col) { let n = 0; for (let i = 0; i < col.length; i++) n = n * 26 + col.charCodeAt(i) - 64; return n - 1; }

function parseSheetMatrix(xml, sharedStrings) {
  const rowMatches = xml.match(/<row\b[^>]*>[\s\S]*?<\/row>/g) || [];
  return rowMatches.map(rowXml => {
    const cells = {};
    const cMatches = rowXml.match(/<c\b[^>]*>[\s\S]*?<\/c>/g) || [];
    for (const cXml of cMatches) {
      const refM = cXml.match(/\br="([A-Z]+)\d+"/);
      if (!refM) continue;
      const colIdx  = colToIdx(refM[1]);
      const isStr    = /\bt="s"/.test(cXml);
      const isInline = /\bt="inlineStr"/.test(cXml);
      let val = '';
      if (isInline) { const im = cXml.match(/<t[^>]*>([^<]*)<\/t>/); val = im ? xmlUnesc(im[1]) : ''; }
      else {
        const vm = cXml.match(/<v>([^<]*)<\/v>/);
        if (vm) { if (isStr) { const idx = parseInt(vm[1],10); val = (Number.isFinite(idx) && sharedStrings[idx] !== undefined) ? sharedStrings[idx] : ''; } else val = vm[1]; }
      }
      cells[colIdx] = val;
    }
    return cells;
  });
}

function detectHeader(matrix) {
  const CODE_K  = ['masp','ma','productcode','sku','code','itemcode','mã','mahang'];
  const NAME_K  = ['tensp','ten','tensanpham','productname','name','itemname'];
  const STOCK_K = ['tonkho','currentstock','tonhientai','ton','stock','tondauky'];
  const TRAN_K  = ['hangduong','intransit','transit','hangtrenvanchuyen','hangdi'];
  const FORE_K  = ['tondukien','forecaststock','forecast','toncuoiky'];
  const MIN_K   = ['tonmin','minstock','min','toithieu','minimumstock'];
  const MAX_K   = ['tonmax','maxstock','max','toidatoi','maximumstock'];
  for (let ri = 0; ri < Math.min(10, matrix.length); ri++) {
    const row = matrix[ri];
    const cols = Object.keys(row).map(Number).sort((a,b)=>a-b);
    let codeC=-1,nameC=-1,stockC=-1,tranC=-1,foreC=-1,minC=-1,maxC=-1;
    for (const c of cols) {
      const k = nk(row[c]);
      if (codeC<0 && CODE_K.includes(k))  codeC=c;
      if (nameC<0 && NAME_K.includes(k))  nameC=c;
      if (stockC<0 && STOCK_K.includes(k)) stockC=c;
      if (tranC<0 && TRAN_K.includes(k))  tranC=c;
      if (foreC<0 && FORE_K.includes(k))  foreC=c;
      if (minC<0 && MIN_K.includes(k))   minC=c;
      if (maxC<0 && MAX_K.includes(k))   maxC=c;
    }
    if (codeC>=0 && nameC>=0 && minC>=0 && maxC>=0) return { headerRowIdx:ri, colIdx:{code:codeC,name:nameC,stock:stockC,transit:tranC,forecast:foreC,min:minC,max:maxC} };
  }
  return null;
}

function extractRowsFromMatrix(matrix, headerRowIdx, colIdx) {
  const result = [];
  for (let ri = headerRowIdx+1; ri < matrix.length; ri++) {
    const row = matrix[ri];
    const code = clean(String(row[colIdx.code] || ''));
    const name = clean(String(row[colIdx.name] || ''));
    if (!code || code.length < 1) continue;
    const pn = (v) => { const n = parseNum(String(v ?? '')); return Number.isFinite(n) ? n : NaN; };
    const stock    = colIdx.stock    >= 0 ? pn(row[colIdx.stock])    : 0;
    const transit  = colIdx.transit  >= 0 ? pn(row[colIdx.transit])  : 0;
    const forecast = colIdx.forecast >= 0 ? pn(row[colIdx.forecast]) : NaN;
    const min      = pn(row[colIdx.min]);
    const max      = pn(row[colIdx.max]);
    if (!Number.isFinite(min) || !Number.isFinite(max)) continue;
    if (min === 0 && max === 0) continue;
    result.push({ code, name: name||code, current: Number.isFinite(stock)?stock:0, transit: Number.isFinite(transit)?transit:0, forecast: Number.isFinite(forecast)?forecast:(stock||0)+(transit||0), min, max });
  }
  return result;
}

function extractXlsxData(files, sharedStrings) {
  const sheetKeys = Object.keys(files).filter(k => /xl\/worksheets\/sheet\d*\.xml$/i.test(k)).sort();
  let bestRows = [];
  for (const key of sheetKeys) {
    const xml    = decodeUTF8(files[key]);
    const matrix = parseSheetMatrix(xml, sharedStrings);
    if (matrix.length < 3) continue;
    const hdr = detectHeader(matrix);
    if (!hdr) continue;
    const rows = extractRowsFromMatrix(matrix, hdr.headerRowIdx, hdr.colIdx);
    if (rows.length > bestRows.length) bestRows = rows;
  }
  return bestRows;
}
